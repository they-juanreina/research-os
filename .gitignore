# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# Personal knowledge tooling (Obsidian workspaces are user-specific)
.obsidian/

# AI assistant configs (per-user, not for distribution)
.github/copilot/
.copilot/
.cursor/
.cursorrules

# Claude Code local-only settings (the global settings.json IS shared, but
# settings.local.json holds the user's machine-specific permission allowlist)
settings.local.json
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/

# Secrets and environment files
.env
.env.*
.env.local
.env.*.local
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx

# Node (for Playwright projects)
node_modules/
dist/

# Temp files
*.tmp
*.log

# Claude Code worktrees (local only)
worktrees/

# Bundled services — local venvs, secrets, and runtime outputs
# (no trailing slashes so the patterns also match symlinks pointing at venvs)
services/*/.venv
services/*/.env
services/*/outputs/
services/*/__pycache__/
